---
import GoogleIcon from '../assets/icons/google.svg'
import MoonIcon from '../assets/icons/moon.svg'
---

<div class="card bg-primary text-primary-content shadow-xl w-full max-w-md">
  <div class="card-body items-center text-center">
    <div class="mb-4">
      <MoonIcon width="48" height="48" class="text-primary-content" />
    </div>

    <h2 class="card-title text-2xl mb-2">Welcome to Lunar Reminder</h2>
    <p class="text-primary-content/80 mb-6 text-lg">
      Over the moon, on time, every time.
    </p>

    <button id="btn-google-auth" class="btn btn-neutral btn-lg w-full gap-2">
      <GoogleIcon width="24" height="24" />
      Continue with Google
    </button>

    <p class="text-xs text-primary-content/60 mt-6">
      By signing in, you agree to our
      <a href="#" class="link link-hover">Terms of Service</a> and
      <a href="#" class="link link-hover">Privacy Policy</a>
    </p>
  </div>
</div>

<script>
  import { authClient } from '../lib/auth-client.ts'

  const btnGoogleAuth = document.getElementById('btn-google-auth')
  btnGoogleAuth?.addEventListener('click', async () => {
    await authClient.signIn.social({
      provider: 'google',
      callbackURL: '/upcoming',
      errorCallbackURL: '/'
    })
  })
</script>
